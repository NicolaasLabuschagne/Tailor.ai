# Google Gemini API
# Get at: https://aistudio.google.com/app/apikey
GROQ_API_KEY=

# NewsAPI — 100 req/day free
# Sign up: newsapi.org/register
NEWSAPI_KEY=

# The Guardian — unlimited free
# Sign up: open-platform.theguardian.com
GUARDIAN_API_KEY=

# New York Times — 500 req/day free
# Sign up: developer.nytimes.com
NYT_API_KEY=

# Resend — email delivery
# Sign up: resend.com
RESEND_API_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tailor

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Cron security — generate with: openssl rand -hex 32
CRON_SECRET=

# SMTP Configuration for Magic Links (NextAuth)
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@example.com
